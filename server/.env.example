# Port du serveur (Heroku fournit automatiquement PORT)
PORT=3001

# Connexion MongoDB (Atlas ou local)
MONGODB_URI=mongodb://127.0.0.1:27017/promodev_jeu_ete

# Secret JWT (à remplacer par une valeur longue et aléatoire en prod)
JWT_SECRET=change-me-super-secret-key

# Durée de validité du token
JWT_EXPIRES_IN=30d

# Origines autorisées pour le CORS en dev (séparées par des virgules)
CORS_ORIGIN=http://localhost:5173

# Date de fin de l'opération (pour le décompte finaliste) - ISO
OPERATION_END=2026-09-15T23:59:59.000Z

# --- Mot de passe oublié -----------------------------------------------------
# Ces cinq variables vont ENSEMBLE : il en manque une, et la fonctionnalité
# reste éteinte (le lien « mot de passe oublié » ne s'affiche même pas).
# C'est du SMTP standard : n'importe quel prestataire fait l'affaire.
#
# URL publique du site, utilisée pour construire le lien du mail. Obligatoire et
# JAMAIS déduite de la requête : l'en-tête Host est falsifiable, et un lien
# forgé enverrait le jeton de la victime chez un attaquant.
PUBLIC_URL=http://localhost:5173

# Ex. Brevo : smtp-relay.brevo.com / 587  |  Mailjet : in-v3.mailjet.com / 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Expéditeur affiché. L'adresse doit être autorisée chez le prestataire, sinon
# l'envoi part en spam ou se fait refuser.
MAIL_FROM=Jeu de l'Été PromoDev <hello@promo.dev>

# ⚠️ Ce fichier est SUIVI PAR GIT : il documente les variables, il ne contient
# jamais de valeur réelle. Les secrets vont dans server/.env (ignoré par git) en
# local, et dans `heroku config:set` en production.
#
# Mailjet : le couple SMTP est celui des clés API.
#   SMTP_USER = clé API PUBLIQUE   SMTP_PASS = clé API PRIVÉE (secrète)